# This repo keeps each app's secrets in its OWN env file (gitignored):
#   apps/chat_bot/.env
#   apps/palette-vein/.env
# Copy the blocks below into those files and fill in real values.

# ── apps/chat_bot/.env ───────────────────────────────────────────
# API_KEY=<random secret for the chat API>
# OLLAMA_HOST=http://172.17.0.1:11434
# OLLAMA_EMBED_MODEL=bge-m3
# GPU_DEVICES=0,1            # optional: GPUs Ollama may use
# OLLAMA_PARALLEL=2          # optional

# ── apps/palette-vein/.env ───────────────────────────────────────
# COMPOSE_PROJECT_NAME=palettevein
# JWT_SECRET=<openssl rand -hex 32>
# POSTGRES_PASSWORD=<openssl rand -hex 24>
# EMBED_DELAY_MS=300
# SECURE_COOKIE=true         # true behind Cloudflare Tunnel (HTTPS)
# ALLOWED_ORIGIN=            # optional, only if frontend served cross-origin
